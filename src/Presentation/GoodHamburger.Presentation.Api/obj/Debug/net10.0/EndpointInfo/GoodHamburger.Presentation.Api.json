{
  "openapi": "3.1.1",
  "info": {
    "title": "GoodHamburger.Presentation.Api | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5126"
    }
  ],
  "paths": {
    "/Order": {
      "post": {
        "tags": [
          "Order"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ResultOfUnit"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultOfUnit"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultOfUnit"
                }
              }
            }
          }
        }
      }
    },
    "/Product": {
      "post": {
        "tags": [
          "Product"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProductCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProductCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProductCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ResultOfUnit"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultOfUnit"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultOfUnit"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateOrderCommand": {
        "required": [
          "name",
          "phoneNumber",
          "items"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateOrderItemCommand"
            }
          }
        }
      },
      "CreateOrderItemCommand": {
        "required": [
          "productId"
        ],
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "CreateProductCommand": {
        "required": [
          "name",
          "price"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "price": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "DomainError": {
        "required": [
          "error",
          "description"
        ],
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "ResultOfUnit": {
        "required": [
          "data"
        ],
        "type": "object",
        "properties": {
          "message": {
            "type": [
              "null",
              "string"
            ]
          },
          "errors": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "$ref": "#/components/schemas/DomainError"
            }
          },
          "data": {
            "$ref": "#/components/schemas/Unit"
          }
        }
      },
      "Unit": {
        "type": "object"
      }
    }
  },
  "tags": [
    {
      "name": "Order"
    },
    {
      "name": "Product"
    }
  ]
}